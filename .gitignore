# --- venv & build artifacts -------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# --- uv / pip ---------------------------------------------------------------
uv.lock.bak

# --- outputs (regenerated by train.py / predict.py) -------------------------
/models/
/predictions/
/logs/
/wandb/
/mlruns/

# --- data: ignore every file under data/, allow only a placeholder README ---
/data/*
!/data/.gitkeep
!/data/README.md

# --- Jupyter notebooks: strip outputs from any notebook by default ----------
# Outputs can leak data snippets and absolute paths. CI enforces stripping.
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# --- secrets / envs ---------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
credentials.json
client_secret*.json
*.credentials
.secrets/
secrets/

# --- editors / os -----------------------------------------------------------
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- HF caches that sometimes end up in-tree --------------------------------
/.cache/
/hf-cache/
